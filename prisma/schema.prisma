generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum ImportStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum ImportIssueLevel {
  WARNING
  ERROR
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userTenants    UserTenant[]
  wxUserTenants  WxUserTenant[]
  customers      Customer[]
  optometryExams OptometryExam[]
  importBatches  ImportBatch[]
}

model User {
  id           String   @id @default(cuid())
  account      String   @unique
  name         String
  mobile       String?
  email        String?
  passwordHash String
  passwordSalt String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userTenants UserTenant[]
  sessions    Session[]
}

model UserTenant {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model WxUser {
  id         String   @id @default(cuid())
  openId     String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  wxUserTenants WxUserTenant[]
  wxSessions    WxSession[]
}

model WxUserTenant {
  id        String   @id @default(cuid())
  wxUserId  String
  tenantId  String
  createdAt DateTime @default(now())

  wxUser WxUser @relation(fields: [wxUserId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([wxUserId, tenantId])
  @@index([tenantId])
}

model WxSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  wxUserId  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  wxUser WxUser @relation(fields: [wxUserId], references: [id], onDelete: Cascade)

  @@index([wxUserId])
  @@index([expiresAt])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Customer {
  id               String   @id @default(cuid())
  tenantId         String
  sourceCustomerId String
  name             String
  gender           String?
  pinyin           String?
  primaryPhone     String?
  secondaryPhone   String?
  note             String?
  sourceCreatedAt  DateTime?
  rawRow           Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  optometryExams  OptometryExam[]

  @@unique([tenantId, sourceCustomerId])
  @@index([tenantId, name])
  @@index([tenantId, primaryPhone])
}

model OptometryExam {
  id               String   @id @default(cuid())
  tenantId         String
  customerId       String
  sourceCustomerId String
  examAt           DateTime
  distanceRight    Json
  distanceLeft     Json
  nearRight        Json
  nearLeft         Json
  pupil            Json
  comment          String?
  rawRow           Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sourceCustomerId, examAt])
  @@index([tenantId, examAt])
  @@index([customerId, examAt])
}

model ImportBatch {
  id                 String       @id @default(cuid())
  tenantId           String
  status             ImportStatus @default(RUNNING)
  customerFile       String
  optometryFile      String
  customerRows       Int          @default(0)
  importedCustomers  Int          @default(0)
  optometryRows      Int          @default(0)
  importedOptometry  Int          @default(0)
  skippedOptometry   Int          @default(0)
  warningCount       Int          @default(0)
  errorCount         Int          @default(0)
  startedAt          DateTime     @default(now())
  finishedAt         DateTime?

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  issues ImportIssue[]

  @@index([tenantId, startedAt])
}

model ImportIssue {
  id        String           @id @default(cuid())
  batchId   String
  level     ImportIssueLevel
  entity    String
  sourceId  String?
  rowNumber Int?
  message   String
  rawRow    Json?
  createdAt DateTime         @default(now())

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, level])
}
